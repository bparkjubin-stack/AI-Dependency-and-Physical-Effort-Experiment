<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Questionnaire</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="q-page">
    <h1>Post-task questionnaire</h1>
    <p class="text-muted" style="margin-bottom:24px;">Please answer the following questions based on your experience during the tasks. There are no right or wrong answers.</p>

    <!-- UWES-9 (Utrecht Work Engagement Scale, adapted) -->
    <div class="q-section" id="uwes">
      <h3>Section 1: Task engagement</h3>
      <p class="text-muted">How did you feel during the decision tasks?</p>
      <div class="q-item" data-scale="uwes" data-item="1">
        <label>I felt energized while working on the tasks.</label>
        <div class="q-likert" data-name="uwes_1">
          <label><input type="radio" name="uwes_1" value="0"><span>Never</span></label>
          <label><input type="radio" name="uwes_1" value="1"><span>Rarely</span></label>
          <label><input type="radio" name="uwes_1" value="2"><span>Sometimes</span></label>
          <label><input type="radio" name="uwes_1" value="3"><span>Often</span></label>
          <label><input type="radio" name="uwes_1" value="4"><span>Always</span></label>
        </div>
      </div>
      <div class="q-item">
        <label>I felt focused and absorbed in the decision-making.</label>
        <div class="q-likert"><label><input type="radio" name="uwes_2" value="0"><span>Never</span></label><label><input type="radio" name="uwes_2" value="1"><span>Rarely</span></label><label><input type="radio" name="uwes_2" value="2"><span>Sometimes</span></label><label><input type="radio" name="uwes_2" value="3"><span>Often</span></label><label><input type="radio" name="uwes_2" value="4"><span>Always</span></label></div>
      </div>
      <div class="q-item">
        <label>I was enthusiastic about the tasks.</label>
        <div class="q-likert"><label><input type="radio" name="uwes_3" value="0"><span>Never</span></label><label><input type="radio" name="uwes_3" value="1"><span>Rarely</span></label><label><input type="radio" name="uwes_3" value="2"><span>Sometimes</span></label><label><input type="radio" name="uwes_3" value="3"><span>Often</span></label><label><input type="radio" name="uwes_3" value="4"><span>Always</span></label></div>
      </div>
      <div class="q-item">
        <label>I felt mentally alert and attentive throughout.</label>
        <div class="q-likert"><label><input type="radio" name="uwes_4" value="0"><span>Never</span></label><label><input type="radio" name="uwes_4" value="1"><span>Rarely</span></label><label><input type="radio" name="uwes_4" value="2"><span>Sometimes</span></label><label><input type="radio" name="uwes_4" value="3"><span>Often</span></label><label><input type="radio" name="uwes_4" value="4"><span>Always</span></label></div>
      </div>
    </div>

    <!-- AI Trust Scale -->
    <div class="q-section" id="trust">
      <h3>Section 2: AI assistant perception</h3>
      <p class="text-muted">How did you perceive the AI assistant?</p>
      <div class="q-item">
        <label>I trusted the AI assistant's recommendations.</label>
        <div class="q-likert"><label><input type="radio" name="trust_1" value="1"><span>Strongly disagree</span></label><label><input type="radio" name="trust_1" value="2"><span>Disagree</span></label><label><input type="radio" name="trust_1" value="3"><span>Neutral</span></label><label><input type="radio" name="trust_1" value="4"><span>Agree</span></label><label><input type="radio" name="trust_1" value="5"><span>Strongly agree</span></label></div>
      </div>
      <div class="q-item">
        <label>I felt the AI's analysis was accurate.</label>
        <div class="q-likert"><label><input type="radio" name="trust_2" value="1"><span>Strongly disagree</span></label><label><input type="radio" name="trust_2" value="2"><span>Disagree</span></label><label><input type="radio" name="trust_2" value="3"><span>Neutral</span></label><label><input type="radio" name="trust_2" value="4"><span>Agree</span></label><label><input type="radio" name="trust_2" value="5"><span>Strongly agree</span></label></div>
      </div>
      <div class="q-item">
        <label>I double-checked the AI's claims against the data table.</label>
        <div class="q-likert"><label><input type="radio" name="trust_3" value="1"><span>Never</span></label><label><input type="radio" name="trust_3" value="2"><span>Rarely</span></label><label><input type="radio" name="trust_3" value="3"><span>Sometimes</span></label><label><input type="radio" name="trust_3" value="4"><span>Often</span></label><label><input type="radio" name="trust_3" value="5"><span>Always</span></label></div>
      </div>
      <div class="q-item">
        <label>I noticed instances where the AI might have been wrong.</label>
        <div class="q-likert"><label><input type="radio" name="trust_4" value="1"><span>Strongly disagree</span></label><label><input type="radio" name="trust_4" value="2"><span>Disagree</span></label><label><input type="radio" name="trust_4" value="3"><span>Neutral</span></label><label><input type="radio" name="trust_4" value="4"><span>Agree</span></label><label><input type="radio" name="trust_4" value="5"><span>Strongly agree</span></label></div>
      </div>
    </div>

    <!-- Metacognitive Awareness (short) -->
    <div class="q-section" id="meta">
      <h3>Section 3: Self-reflection</h3>
      <p class="text-muted">Thinking about how you made your decisions...</p>
      <div class="q-item">
        <label>I was aware of my own thinking process while making decisions.</label>
        <div class="q-likert"><label><input type="radio" name="meta_1" value="1"><span>Strongly disagree</span></label><label><input type="radio" name="meta_1" value="2"><span>Disagree</span></label><label><input type="radio" name="meta_1" value="3"><span>Neutral</span></label><label><input type="radio" name="meta_1" value="4"><span>Agree</span></label><label><input type="radio" name="meta_1" value="5"><span>Strongly agree</span></label></div>
      </div>
      <div class="q-item">
        <label>I questioned my own assumptions before finalizing answers.</label>
        <div class="q-likert"><label><input type="radio" name="meta_2" value="1"><span>Strongly disagree</span></label><label><input type="radio" name="meta_2" value="2"><span>Disagree</span></label><label><input type="radio" name="meta_2" value="3"><span>Neutral</span></label><label><input type="radio" name="meta_2" value="4"><span>Agree</span></label><label><input type="radio" name="meta_2" value="5"><span>Strongly agree</span></label></div>
      </div>
      <div class="q-item">
        <label>I monitored whether my confidence matched my actual understanding.</label>
        <div class="q-likert"><label><input type="radio" name="meta_3" value="1"><span>Strongly disagree</span></label><label><input type="radio" name="meta_3" value="2"><span>Disagree</span></label><label><input type="radio" name="meta_3" value="3"><span>Neutral</span></label><label><input type="radio" name="meta_3" value="4"><span>Agree</span></label><label><input type="radio" name="meta_3" value="5"><span>Strongly agree</span></label></div>
      </div>
    </div>

    <!-- Demographics -->
    <div class="q-section" id="demo">
      <h3>Section 4: About you</h3>
      <div class="q-item">
        <label>Age</label>
        <input type="number" name="age" class="form-input" style="max-width:120px" placeholder="e.g. 25" min="18" max="99">
      </div>
      <div class="q-item">
        <label>How often do you use AI tools (ChatGPT, Claude, etc.) in your daily work?</label>
        <div class="q-likert"><label><input type="radio" name="ai_usage" value="1"><span>Never</span></label><label><input type="radio" name="ai_usage" value="2"><span>Rarely</span></label><label><input type="radio" name="ai_usage" value="3"><span>Weekly</span></label><label><input type="radio" name="ai_usage" value="4"><span>Daily</span></label><label><input type="radio" name="ai_usage" value="5"><span>Constantly</span></label></div>
      </div>
    </div>

    <button class="btn btn-primary btn-block" onclick="submitAll()" id="btnSubmitQ" style="margin-top:8px;">
      Submit & continue
    </button>
    <p id="qError" style="color:#991b1b; font-size:13px; margin-top:8px; display:none;"></p>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const PID = '<%= pid %>';
    const socket = io();

    function collectScale(prefix, count) {
      const responses = {};
      for (let i = 1; i <= count; i++) {
        const name = prefix + '_' + i;
        const checked = document.querySelector(`input[name="${name}"]:checked`);
        if (checked) responses[name] = parseInt(checked.value);
        else return null; // incomplete
      }
      return responses;
    }

    function submitAll() {
      const uwes = collectScale('uwes', 4);
      const trust = collectScale('trust', 4);
      const meta = collectScale('meta', 3);
      const aiUsage = document.querySelector('input[name="ai_usage"]:checked');
      const age = document.querySelector('input[name="age"]').value;

      if (!uwes || !trust || !meta || !aiUsage) {
        document.getElementById('qError').textContent = 'Please answer all questions before submitting.';
        document.getElementById('qError').style.display = 'block';
        return;
      }

      socket.emit('questionnaire:save', { pid: PID, scaleName: 'uwes', responses: uwes });
      socket.emit('questionnaire:save', { pid: PID, scaleName: 'trust', responses: trust });
      socket.emit('questionnaire:save', { pid: PID, scaleName: 'metacognition', responses: meta });
      socket.emit('questionnaire:save', { pid: PID, scaleName: 'demographics', responses: { age: parseInt(age) || null, ai_usage: parseInt(aiUsage.value) } });

      document.getElementById('btnSubmitQ').disabled = true;
      document.getElementById('btnSubmitQ').textContent = 'Saving...';

      socket.emit('questionnaire:complete', { pid: PID });
    }

    socket.on('questionnaire:done', ({ url }) => {
      window.location.href = url;
    });
  </script>
</body>
</html>
