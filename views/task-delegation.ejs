<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Cognitive Tasks</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-center">
    <div class="card card-wide">
      <div class="progress-bar"><% for(let i=1;i<=totalPhases;i++){%><div class="step <%=i<phase?'done':i===phase?'active':''%>"></div><%}%></div>
      <h1>Cognitive Tasks</h1>
      <p>You will now complete 3 tasks. <strong>Please delegate each task to the AI Assistant</strong> — type your request in the chat, and the AI will generate an answer for you. Review briefly, then submit.</p>
      <div class="task-step-indicator" id="stepIndicator"></div>
      <div id="taskArea"></div>
    </div>
  </div>
  <script>
    var pid = '<%= pid %>';
    var tasks = <%- JSON.stringify(tasks) %>;
    var currentTask = 0;
    var taskStartTime = Date.now();

    function renderStep() {
      var ind = document.getElementById('stepIndicator');
      ind.innerHTML = tasks.map(function(t,i){
        var cls = i < currentTask ? 'done' : i === currentTask ? 'active' : '';
        return '<div class="task-step-dot '+cls+'">'+(i+1)+'</div>';
      }).join('');
    }

    function renderTask() {
      renderStep();
      taskStartTime = Date.now();
      if (currentTask >= tasks.length) { finishTasks(); return; }
      var t = tasks[currentTask];
      var html = '<h2>Task '+(currentTask+1)+': '+t.title+'</h2>';
      html += '<p style="color:#555;font-size:0.9rem;margin:8px 0 16px;">'+t.instruction+'</p>';
      html += '<div class="task-layout">';
      // Left: material
      html += '<div class="task-panel">';
      if(t.material) html += '<div class="task-material">'+t.material+'</div>';
      else html += '<p class="text-muted">No additional material for this task.</p>';
      html += '</div>';
      // Right: chat
      html += '<div class="task-panel">';
      html += '<h3>AI Assistant</h3>';
      html += '<div class="chat-panel" id="chatPanel">';
      html += '<div class="chat-messages" id="chatMessages"></div>';
      html += '<div class="chat-input-row"><input type="text" id="chatInput" placeholder="Type your request to the AI..." onkeydown="if(event.key===\'Enter\')sendChat()"><button id="sendBtn" onclick="sendChat()">Send</button></div>';
      html += '</div>';
      html += '<button class="btn btn-primary btn-full mt-16" id="submitTaskBtn" style="display:none;" onclick="submitTask()">Submit AI\'s Answer</button>';
      html += '</div></div>';
      document.getElementById('taskArea').innerHTML = html;
    }

    var lastAIResponse = '';
    function sendChat() {
      var input = document.getElementById('chatInput');
      var msg = input.value.trim();
      if(!msg) return;
      input.value = '';
      document.getElementById('sendBtn').disabled = true;
      // Show user message
      var msgs = document.getElementById('chatMessages');
      msgs.innerHTML += '<div class="chat-msg user"><div class="label">You</div><div class="bubble">'+escHtml(msg)+'</div></div>';
      msgs.innerHTML += '<div class="chat-loading" id="loading">AI is thinking...</div>';
      msgs.scrollTop = msgs.scrollHeight;
      // Call API
      fetch('/api/ai-chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt:msg,taskNumber:tasks[currentTask].number})})
      .then(function(r){return r.json();}).then(function(d){
        var el = document.getElementById('loading');
        if(el) el.remove();
        lastAIResponse = d.response;
        msgs.innerHTML += '<div class="chat-msg ai"><div class="label">AI Assistant</div><div class="bubble">'+escHtml(d.response)+'</div></div>';
        msgs.scrollTop = msgs.scrollHeight;
        document.getElementById('sendBtn').disabled = false;
        document.getElementById('submitTaskBtn').style.display = 'block';
        // Store prompt for saving
        document.getElementById('submitTaskBtn').dataset.prompt = msg;
      });
    }

    function submitTask() {
      var prompt = document.getElementById('submitTaskBtn').dataset.prompt || '';
      var timeSpent = Date.now() - taskStartTime;
      fetch('/api/task-response',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        pid:pid, task_number:tasks[currentTask].number, condition:'delegation',
        prompt_sent:prompt, ai_response:lastAIResponse, submitted_answer:lastAIResponse, time_spent_ms:timeSpent
      })}).then(function(){
        currentTask++;
        lastAIResponse = '';
        renderTask();
      });
    }

    function finishTasks() {
      fetch('/api/tasks-complete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pid:pid})})
      .then(function(r){return r.json();}).then(function(d){if(d.next)window.location.href=d.next;});
    }

    function escHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');}
    renderTask();
  </script>
</body>
</html>
