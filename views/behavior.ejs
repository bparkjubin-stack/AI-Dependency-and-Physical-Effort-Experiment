<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Bonus Activity</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-center">
    <div class="card">
      <div class="progress-bar"><% for(let i=1;i<=totalPhases;i++){%><div class="step <%=i<phase?'done':i===phase?'active':''%>"></div><%}%></div>
      <h1>Thank You for Completing the Questionnaires!</h1>
      <p>The system is now processing your data, which will take approximately 2 minutes. In the meantime, you may choose one of the following activities:</p>
      <div class="behavior-options">
        <div class="behavior-card" id="stretchCard" onclick="selectBehavior('stretch')">
          <div class="emoji">🧘</div>
          <div class="title">Desk Stretches</div>
          <div class="desc">Follow on-screen instructions to complete a simple set of desk stretches (approx. 2 minutes).</div>
          <div class="bonus">&pound;0.45 bonus</div>
        </div>
        <div class="behavior-card" id="waitCard" onclick="selectBehavior('wait')">
          <div class="emoji">⏳</div>
          <div class="title">Wait Quietly</div>
          <div class="desc">Wait quietly while the system finishes processing (approx. 2 minutes).</div>
          <div class="bonus">&pound;0.15 bonus</div>
        </div>
      </div>
      <button class="btn btn-primary btn-full" id="confirmBtn" disabled onclick="confirmBehavior()">Confirm Choice</button>
    </div>
  </div>
  <script>
    var pid = '<%= pid %>';
    var choice = null;
    function selectBehavior(c) {
      choice = c;
      document.getElementById('stretchCard').classList.toggle('selected', c==='stretch');
      document.getElementById('waitCard').classList.toggle('selected', c==='wait');
      document.getElementById('confirmBtn').disabled = false;
    }
    function confirmBehavior() {
      fetch('/api/behavior',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pid:pid,choice:choice})})
      .then(function(r){return r.json();}).then(function(d){if(d.next)window.location.href=d.next;});
    }
  </script>
</body>
</html>
