<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>About You</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-center">
    <div class="card">
      <div class="progress-bar"><% for(let i=1;i<=totalPhases;i++){%><div class="step <%=i<phase?'done':i===phase?'active':''%>"></div><%}%></div>
      <h1>About You</h1>
      <p class="subtitle">A few quick questions before we begin.</p>

      <div class="mb-16">
        <label class="field-label">Age</label>
        <input type="number" id="age" min="18" max="99" placeholder="e.g. 25">
      </div>
      <div class="mb-16">
        <label class="field-label">Gender</label>
        <div class="choice-group" id="gender" style="flex-direction:row;flex-wrap:wrap;gap:8px;">
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'gender','male')"><div class="choice-dot"></div><span class="choice-text">Male</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'gender','female')"><div class="choice-dot"></div><span class="choice-text">Female</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'gender','non-binary')"><div class="choice-dot"></div><span class="choice-text">Non-binary</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'gender','prefer_not')"><div class="choice-dot"></div><span class="choice-text">Prefer not to say</span></div>
        </div>
      </div>
      <div class="mb-16">
        <label class="field-label">Highest education level</label>
        <select id="education"><option value="">Select...</option><option value="high_school">High school or below</option><option value="associate">Associate degree</option><option value="bachelor">Bachelor's degree</option><option value="master">Master's degree</option><option value="doctoral">Doctoral degree</option></select>
      </div>
      <div class="mb-16">
        <label class="field-label">Occupation</label>
        <select id="occupation"><option value="">Select...</option><option value="student">Student</option><option value="full_time">Employed full-time</option><option value="part_time">Employed part-time</option><option value="self_employed">Self-employed</option><option value="other">Other</option></select>
      </div>
      <div class="mb-16">
        <label class="field-label">How many times per week do you do moderate-to-vigorous exercise?</label>
        <div class="choice-group" id="exercise" style="flex-direction:row;flex-wrap:wrap;gap:8px;">
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'exercise','never')"><div class="choice-dot"></div><span class="choice-text">Never</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'exercise','1-2')"><div class="choice-dot"></div><span class="choice-text">1–2 times</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'exercise','3-4')"><div class="choice-dot"></div><span class="choice-text">3–4 times</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'exercise','5+')"><div class="choice-dot"></div><span class="choice-text">5+ times</span></div>
        </div>
      </div>
      <div class="mb-24">
        <label class="field-label">How often do you use AI tools (e.g., ChatGPT, Claude, Gemini)?</label>
        <div class="choice-group" id="ai_usage" style="flex-direction:row;flex-wrap:wrap;gap:8px;">
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'ai_usage','never')"><div class="choice-dot"></div><span class="choice-text">Never</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'ai_usage','occasionally')"><div class="choice-dot"></div><span class="choice-text">Occasionally</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'ai_usage','regularly')"><div class="choice-dot"></div><span class="choice-text">Regularly</span></div>
          <div class="choice-option" style="flex:unset;padding:10px 18px;" onclick="selectRadio(this,'ai_usage','daily')"><div class="choice-dot"></div><span class="choice-text">Almost daily</span></div>
        </div>
      </div>
      <button class="btn btn-primary btn-full" id="nextBtn" onclick="submitDemographics()">Continue</button>
      <div class="error" id="errorMsg" style="display:none;margin-top:8px;"></div>
    </div>
  </div>
  <script>
    var selections = {};
    function selectRadio(el, group, value) {
      document.querySelectorAll('#'+group+' .choice-option').forEach(o=>o.classList.remove('selected'));
      el.classList.add('selected');
      selections[group] = value;
    }
    function submitDemographics() {
      var age = document.getElementById('age').value;
      var edu = document.getElementById('education').value;
      var occ = document.getElementById('occupation').value;
      if(!age||!selections.gender||!edu||!occ||!selections.exercise||!selections.ai_usage){
        document.getElementById('errorMsg').textContent='Please answer all questions.';
        document.getElementById('errorMsg').style.display='block'; return;
      }
      fetch('/api/demographics',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        pid:'<%= pid %>',age:age,gender:selections.gender,education:edu,occupation:occ,
        exercise_freq:selections.exercise,ai_usage_freq:selections.ai_usage
      })}).then(r=>r.json()).then(d=>{if(d.next)window.location.href=d.next;});
    }
  </script>
</body>
</html>
