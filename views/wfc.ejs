<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Word Game</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-center">
    <div class="card">
      <div class="progress-bar"><% for(let i=1;i<=totalPhases;i++){%><div class="step <%=i<phase?'done':i===phase?'active':''%>"></div><%}%></div>
      <h1>Quick Word Game</h1>
      <p class="subtitle" id="instrText">You will see word fragments with missing letters. Complete each with the <strong>first English word that comes to mind</strong>. You have 10 seconds per item.</p>
      <button class="btn btn-primary btn-full" id="startBtn" onclick="startWFC()">Start</button>
      <div id="wfcArea" style="display:none;">
        <div class="wfc-container">
          <div class="wfc-timer">Time remaining: <span class="time" id="timer">10</span>s</div>
          <div class="wfc-fragment" id="fragment"></div>
          <input type="text" class="wfc-input" id="wfcInput" placeholder="Type a word..." autocomplete="off" autofocus onkeydown="if(event.key==='Enter')submitFragment()">
          <div><button class="btn btn-primary" onclick="submitFragment()">Next</button></div>
          <div class="wfc-counter" id="counter"></div>
        </div>
      </div>
    </div>
  </div>
  <script>
    var pid = '<%= pid %>';
    var items = <%- items %>;
    var current = 0;
    var responses = [];
    var timerInterval = null;
    var timeLeft = 10;
    var fragmentStart = 0;

    function startWFC() {
      document.getElementById('startBtn').style.display = 'none';
      document.getElementById('instrText').style.display = 'none';
      document.getElementById('wfcArea').style.display = 'block';
      showFragment();
    }

    function showFragment() {
      if (current >= items.length) { finishWFC(); return; }
      var item = items[current];
      document.getElementById('fragment').textContent = item.fragment;
      document.getElementById('wfcInput').value = '';
      document.getElementById('wfcInput').focus();
      document.getElementById('counter').textContent = (current+1) + ' / ' + items.length;
      timeLeft = 10;
      fragmentStart = Date.now();
      updateTimer();
      timerInterval = setInterval(function(){
        timeLeft--;
        updateTimer();
        if(timeLeft <= 0) { submitFragment(true); }
      }, 1000);
    }

    function updateTimer() {
      var el = document.getElementById('timer');
      el.textContent = timeLeft;
      el.className = 'time' + (timeLeft <= 3 ? ' warn' : '');
    }

    function submitFragment(timedOut) {
      clearInterval(timerInterval);
      var item = items[current];
      var resp = document.getElementById('wfcInput').value.trim();
      var rt = Date.now() - fragmentStart;
      responses.push({
        id: item.id, fragment: item.fragment, category: item.category,
        response: resp || null, response_time_ms: rt, timed_out: !!timedOut
      });
      current++;
      showFragment();
    }

    function finishWFC() {
      document.getElementById('wfcArea').innerHTML = '<div class="text-center"><p>Saving your responses...</p></div>';
      fetch('/api/wfc',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pid:pid,responses:responses})})
      .then(function(r){return r.json();}).then(function(d){if(d.next)window.location.href=d.next;});
    }
  </script>
</body>
</html>
