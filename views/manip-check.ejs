<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Final Questions</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-center">
    <div class="card">
      <div class="progress-bar"><% for(let i=1;i<=totalPhases;i++){%><div class="step <%=i<phase?'done':i===phase?'active':''%>"></div><%}%></div>
      <h1>A Few Final Questions</h1>
      <p class="subtitle">Please think back to your earlier experience with the AI-related task. Rate the following based on how you actually felt.</p>
      <div class="progress-text" id="progress">0 / <%= items.length %> answered</div>
      <div id="mcItems"></div>
      <button class="btn btn-primary btn-full mt-24" id="submitBtn" disabled onclick="submitMC()">Continue</button>
    </div>
  </div>
  <script>
    var pid = '<%= pid %>';
    var items = <%- JSON.stringify(items) %>;
    var answers = {};

    function render() {
      var html = '';
      items.forEach(function(item, idx) {
        html += '<div class="scale-item">';
        html += '<div class="item-text">'+(idx+1)+'. '+item.text+'</div>';
        html += '<div class="likert-row">';
        for(var v=1;v<=7;v++){
          html += '<label><input type="radio" name="'+item.id+'" value="'+v+'" onchange="onAnswer(\''+item.id+'\','+v+')"><div class="likert-dot">'+v+'</div></label>';
        }
        html += '</div>';
        html += '<div class="likert-labels"><span>Strongly disagree</span><span>Strongly agree</span></div>';
        html += '</div>';
      });
      document.getElementById('mcItems').innerHTML = html;
    }

    function onAnswer(id, val) {
      answers[id] = val;
      var count = Object.keys(answers).length;
      document.getElementById('progress').textContent = count + ' / ' + items.length + ' answered';
      document.getElementById('submitBtn').disabled = (count < items.length);
    }

    function submitMC() {
      fetch('/api/manip-check',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pid:pid,responses:answers})})
      .then(function(r){return r.json();}).then(function(d){if(d.next)window.location.href=d.next;});
    }

    render();
  </script>
</body>
</html>
